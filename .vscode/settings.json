{
    // *.tmpl files contain Go template syntax ({{ }}) that shellcheck cannot
    // parse — ignore them entirely rather than suppress individual codes.
    "shellcheck.ignorePatterns": {
        "**/*.tmpl": true
    },
    "workbench.colorCustomizations": {
        "activityBar.background": "#688f70",
        "titleBar.activeBackground": "#537259",
        "titleBar.activeForeground": "#e7e7e7",
        "activityBar.activeBackground": "#688f70",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#57516f",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#688f70",
        "statusBar.background": "#537259",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#688f70",
        "statusBarItem.remoteBackground": "#537259",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#53725999",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.remoteColor": "#537259"
}