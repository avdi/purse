{{- if eq .chezmoi.os "windows" -}}
# chezmoi run_onchange: install packages (Windows / PowerShell)
#
# Package lists are baked in from .chezmoidata/packages.yaml by the template
# engine. Adding or removing a package changes this script's rendered content,
# which causes chezmoi to re-run it on the next apply.
#
# Unix/macOS is handled by run_onchange_install-packages.sh.tmpl instead.
#
# winget packages : {{ range .packages.winget }}{{ .id }} {{ end }}
# npm packages    : {{ .packages.npm | join ", " }}
{{ if ne .chezmoi.os "windows" }}
Write-Host "This script is for Windows only. Skipping." -ForegroundColor Yellow
exit 0
{{ end }}
$ErrorActionPreference = 'Stop'

function Test-Command($cmd) {
    return [bool](Get-Command $cmd -ErrorAction SilentlyContinue)
}

function Get-NodeMajor {
    if (-not (Test-Command node)) { return 0 }
    return [int](node -e 'process.stdout.write(process.version.slice(1).split(".")[0])')
}

# ---- winget packages --------------------------------------------------------

if (-not (Test-Command winget)) {
    Write-Error "winget not found. Install the App Installer from the Microsoft Store."
    exit 1
}

Write-Host "→ winget: installing packages..." -ForegroundColor Cyan
{{ range .packages.winget }}
winget install --id {{ .id }} --exact --accept-package-agreements --accept-source-agreements --silent
{{ end }}

# ---- npm packages -----------------------------------------------------------
# Refresh PATH after winget installs Node.js so we don't need a new shell.

$env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
            [System.Environment]::GetEnvironmentVariable('PATH', 'User')

$nodeMajor = Get-NodeMajor
if ($nodeMajor -ge 22) {
    Write-Host "→ npm: {{ .packages.npm | join ", " }}" -ForegroundColor Cyan
    npm install -g {{ .packages.npm | join " " }}
} else {
    $nodeVer = if (Test-Command node) { node --version } else { "none" }
    Write-Warning "Node.js 22+ required (have: $nodeVer). Skipping npm packages:"
    Write-Warning "  {{ .packages.npm | join ", " }}"
    Write-Warning "  Run 'winget upgrade OpenJS.NodeJS.LTS' then re-run chezmoi apply."
}

{{- end -}}
