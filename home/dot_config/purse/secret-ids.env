# ~/.config/purse/secret-ids.env
# Maps environment variable names to Zoho Vault secret IDs.
#
# IDs are non-sensitive numeric identifiers — safe to commit to the dotfiles repo.
#
# How to find a secret's ID:
#   zv search -k "name-of-secret" --name --output json | jq '.[0]'
#
# How to add a new secret:
#   1. Add it to Zoho Vault (title = env var name, password = the secret value)
#   2. Find its ID with the command above
#   3. Add a line below: ENV_VAR_NAME=<numeric-id>
#   4. Run: setup-secrets
#   5. Commit this file back: chezmoi add ~/.config/purse/secret-ids.env
#
# Format: ENV_VAR_NAME=<zoho-vault-numeric-id>
# Lines starting with # are ignored; blank lines are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# AI / LLM tokens
# ANTHROPIC_API_KEY=0
# OPENAI_API_KEY=0
# GOOGLE_API_KEY=0
# AUGMENT_API_KEY=0

# Software licenses
# SUBLIME_TEXT_LICENSE=0
