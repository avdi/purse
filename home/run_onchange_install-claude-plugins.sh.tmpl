{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_onchange: register Claude Code plugin marketplaces and install plugins.
#
# Desired marketplaces and plugins are declared in
# home/.chezmoidata/claude-plugins.yaml and rendered inline below, so chezmoi
# re-runs this script whenever that manifest changes.
#
# Marketplaces are registered before installing plugins: built-in marketplaces
# (e.g. claude-plugins-official) are only auto-seeded on an interactive first
# launch, not under chezmoi's non-interactive apply.
#
# The live ~/.claude/plugins/installed_plugins.json is owned by Claude Code and
# deliberately NOT managed by chezmoi — Claude rewrites it (version, timestamps,
# commit sha) on every install, which would otherwise conflict on each apply.

set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
  echo "⚠️  claude CLI not found; skipping plugin installation" >&2
  exit 0
fi
{{ range $name, $source := .claudePlugins.marketplaces }}
echo "→ claude plugin marketplace add {{ $source }}"
claude plugin marketplace add "{{ $source }}"
{{- end }}
{{ range .claudePlugins.plugins }}
echo "→ claude plugin install {{ . }}"
claude plugin install "{{ . }}"
{{- end }}
{{- end }}
