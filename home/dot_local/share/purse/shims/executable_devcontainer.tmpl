{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# devcontainer shim — when the subcommand is `up`, inject the same dotfiles
# flags the VS Code Dev Containers extension would pass, so the standalone
# CLI installs my dotfiles into new containers automatically. Also forwards
# selected host env vars (GitHub/Bundler tokens by default) into the new
# container via --remote-env, so private-repo auth works out of the box
# without per-project .env wiring. Lazy-fetches tokens via `gh auth token`
# if they aren't already in the host environment.
#
# Defers to the next `devcontainer` on PATH (the real binary, typically the
# symlink npm drops into ~/.local/bin/ that points into node_modules).
#
# Effective only when this directory is on PATH ahead of the real
# devcontainer — see ~/.config/shell/env.sh. Non-interactive shells that
# don't source env.sh hit the real binary directly and skip this shim.

set -euo pipefail

dotfiles_repo="${PURSE_DOTFILES_REPOSITORY:-https://github.com/avdi/purse.git}"
dotfiles_install="${PURSE_DOTFILES_INSTALL_COMMAND:-install.sh}"
dotfiles_target="${PURSE_DOTFILES_TARGET_PATH:-~/dotfiles}"

# Host env vars to forward into the container as --remote-env. Names that are
# unset or empty on the host are skipped silently. Override the list via
# PURSE_DEVCONTAINER_FORWARD_ENV (space-separated).
forward_env_names="${PURSE_DEVCONTAINER_FORWARD_ENV:-GH_TOKEN GITHUB_TOKEN BUNDLE_GITHUB__COM}"

self_canonical="$(realpath "$0" 2>/dev/null || printf '%s' "$0")"

real_devcontainer=""
while IFS= read -r candidate; do
  [ -n "$candidate" ] || continue
  resolved="$(realpath "$candidate" 2>/dev/null || printf '%s' "$candidate")"
  [ "$resolved" = "$self_canonical" ] && continue
  real_devcontainer="$candidate"
  break
done < <(type -aP devcontainer 2>/dev/null || true)

if [ -z "$real_devcontainer" ]; then
  echo "devcontainer shim: real devcontainer CLI not found on PATH" >&2
  echo "  install with: npm install -g @devcontainers/cli" >&2
  exit 127
fi

# Pass through anything that isn't `up` untouched.
if [ "${1:-}" != "up" ]; then
  exec "$real_devcontainer" "$@"
fi

# Detect whether the caller already supplied any --dotfiles-* flag; if so,
# skip our defaults but still forward remote-env vars.
user_dotfiles=0
for arg in "$@"; do
  case "$arg" in
    --dotfiles-repository|--dotfiles-repository=*|\
    --dotfiles-install-command|--dotfiles-install-command=*|\
    --dotfiles-target-path|--dotfiles-target-path=*)
      user_dotfiles=1
      break
      ;;
  esac
done

# Build --remote-env args from forwarded host vars. If a var is unset/empty,
# we attempt to lazy-initialize it using `gh auth token` (if it looks like
# a GitHub token) before skipping.
remote_env_args=()
for name in $forward_env_names; do
  value="${!name:-}"

  # Lazy-fetch GitHub token if needed
  if [ -z "$value" ] && [[ "$name" =~ ^(GH|GITHUB)_TOKEN$|^BUNDLE_GITHUB__COM$ ]]; then
    if command -v gh >/dev/null 2>&1; then
      value="$(gh auth token 2>/dev/null || true)"
    fi
  fi

  [ -n "$value" ] && remote_env_args+=(--remote-env "$name=$value")
done

dotfiles_args=()
if [ "$user_dotfiles" -eq 0 ]; then
  dotfiles_args=(
    --dotfiles-repository "$dotfiles_repo"
    --dotfiles-install-command "$dotfiles_install"
    --dotfiles-target-path "$dotfiles_target"
  )
fi

shift  # consume the `up` subcommand
exec "$real_devcontainer" up \
  "${dotfiles_args[@]+"${dotfiles_args[@]}"}" \
  "${remote_env_args[@]+"${remote_env_args[@]}"}" \
  "$@"
{{- end }}
