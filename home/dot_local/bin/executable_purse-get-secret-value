#!/usr/bin/env bash
# purse-get-secret-value — fetch a secret's value from Zoho Vault by env var name
#
# Usage: purse-get-secret-value ENV_VAR_NAME
#
# Resolves the vault ID from ~/.config/purse/secret-ids.env if present,
# otherwise searches Zoho Vault by name. Then fetches and prints the password value.
#
# Requires: zv, jq, purse-get-secret-id

set -euo pipefail

var_name="${1:?Usage: purse-get-secret-value ENV_VAR_NAME}"

CONFIG_FILE="${HOME}/.config/purse/secret-ids.env"

command -v zv >/dev/null 2>&1 || { echo "zv not found — run: chezmoi apply" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "jq not found" >&2; exit 1; }

# Prefer the locally-recorded ID; fall back to a vault search
vault_id=""
if [[ -f "$CONFIG_FILE" ]]; then
  vault_id=$(grep -E "^${var_name}=[1-9][0-9]*$" "$CONFIG_FILE" | cut -d= -f2 || true)
fi

if [[ -z "$vault_id" ]]; then
  vault_id=$(purse-get-secret-id "$var_name")
fi

raw=$(zv get -id "$vault_id" --not-safe --output json 2>/dev/null) \
  || { echo "Failed to fetch secret id=${vault_id} for ${var_name}" >&2; exit 1; }

printf '%s' "$raw" | jq -re '.secret.secretData[] | select(.id == "password") | .value'
