#!/usr/bin/env bash
# purse-get-secret-value — fetch a secret's value from the PURSE_TOKENS Secure Note
#
# Usage: purse-get-secret-value ENV_VAR_NAME
#
# Looks up the named custom field in the "PURSE_TOKENS" Secure Note in Zoho Vault
# and prints its value.
#
# Requires: zv, jq

set -euo pipefail

var_name="${1:?Usage: purse-get-secret-value ENV_VAR_NAME}"
PURSE_NOTE_NAME="PURSE_TOKENS"

command -v zv >/dev/null 2>&1 || { echo "zv not found — run: chezmoi apply" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "jq not found" >&2; exit 1; }

purse-zv-ensure-auth

note_id=$(zv search -k "$PURSE_NOTE_NAME" --name --strict --output json 2>/dev/null \
  | jq -re --arg name "$PURSE_NOTE_NAME" \
      '.secrets.secret[] | select(.secretname == $name) | .secretid') \
  || { echo "Secure Note '${PURSE_NOTE_NAME}' not found in vault" >&2; exit 1; }

note_raw=$(zv get -id "$note_id" --not-safe --output json 2>/dev/null) \
  || { echo "Failed to fetch note id=${note_id}" >&2; exit 1; }

printf '%s' "$note_raw" \
  | jq -re --arg name "$var_name" \
      '.secret.customcolumn.customcol[] | select(.colname == $name) | .value' \
  || { echo "No field named '${var_name}' in ${PURSE_NOTE_NAME}" >&2; exit 1; }
