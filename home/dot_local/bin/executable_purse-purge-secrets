#!/usr/bin/env bash
# purse-purge-secrets — remove ~/.config/shell/secrets.sh from disk
#
# Usage: purse-purge-secrets
#
# Removes the secrets file written by purse-setup-secrets so that no secrets
# are present on disk. Existing shell sessions are unaffected (vars already
# exported stay in memory); new shells will start without them.

set -euo pipefail

SECRETS_FILE="${HOME}/.config/shell/secrets.sh"

log() { echo "==> $*"; }

if [[ ! -f "$SECRETS_FILE" ]]; then
  log "Nothing to do — ${SECRETS_FILE} does not exist."
  exit 0
fi

rm -f "$SECRETS_FILE"
log "Removed ${SECRETS_FILE}."
echo ""
echo "  New shells will start without the purged secrets."
echo "  To restore them, run: purse-setup-secrets"
