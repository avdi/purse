{{- if eq .chezmoi.os "windows" -}}
# Outfit the installed AI agents (Windows): register the GitKraken MCP server
# and download the codebase-memory-mcp binary.
#
# chezmoi installs this to ~/.local/bin/purse-outfit-agents.ps1.
#
# Run manually, after purse-install-agents.ps1. On Windows the agent-outfitting
# steps are the GitKraken MCP server (`gk mcp install --all`) and downloading
# the codebase-memory-mcp binary. Full declarative MCP-server shortlist
# registration (as done in the Unix purse-outfit-agents) is not yet wired up
# on Windows.
#
# codebase-memory-mcp is registered as an MCP server by the declarative manifest
# (mcp-servers.yaml), not by its own `install -y` which has unwanted side-effects
# (PATH stomping, opinionated CLAUDE.md injection).
#
# Bump $CbmVersion to force a reinstall. Re-running is safe (idempotent).

$ErrorActionPreference = 'Stop'
[Net.ServicePointManager]::SecurityProtocol = `
    [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13

$Repo       = 'DeusData/codebase-memory-mcp'
$CbmVersion = '0.8.1'
$InstallDir = "$env:LOCALAPPDATA\Programs\codebase-memory-mcp"
$BinName    = 'codebase-memory-mcp.exe'
$Dest       = Join-Path $InstallDir $BinName

function Get-InstalledVersion {
    if (-not (Test-Path $Dest)) { return 'none' }
    try {
        $out = & $Dest --version 2>$null
        if ($out -match '([0-9]+\.[0-9]+\.[0-9]+)') { return $Matches[1] }
    } catch {}
    return 'unknown'
}

New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null

if ((Get-InstalledVersion) -ne $CbmVersion) {
    Write-Host "-> codebase-memory-mcp: installing v$CbmVersion..." -ForegroundColor Cyan

    $Archive = 'codebase-memory-mcp-windows-amd64.zip'
    $Base    = "https://github.com/$Repo/releases/download/v$CbmVersion"
    $TmpDir  = Join-Path ([System.IO.Path]::GetTempPath()) "cbm-$(Get-Random)"
    New-Item -ItemType Directory -Path $TmpDir -Force | Out-Null

    try {
        Invoke-WebRequest -Uri "$Base/$Archive" -OutFile "$TmpDir\$Archive" -UseBasicParsing

        # Verify checksum when reachable (non-fatal otherwise).
        try {
            Invoke-WebRequest -Uri "$Base/checksums.txt" -OutFile "$TmpDir\checksums.txt" -UseBasicParsing
            $line = Get-Content "$TmpDir\checksums.txt" | Where-Object { $_ -like "*$Archive*" }
            if ($line) {
                $expected = ($line -split '\s+')[0]
                $actual   = (Get-FileHash -Path "$TmpDir\$Archive" -Algorithm SHA256).Hash.ToLower()
                if ($expected -ne $actual) {
                    throw "checksum mismatch (expected $expected, got $actual)"
                }
            }
        } catch {
            Write-Warning "codebase-memory-mcp: could not verify checksum: $_"
        }

        Expand-Archive -Path "$TmpDir\$Archive" -DestinationPath $TmpDir -Force
        $DlBin = Join-Path $TmpDir $BinName
        if (-not (Test-Path $DlBin)) { throw "binary not found after extraction" }

        # Rename-aside if the existing binary is locked (server running).
        if (Test-Path $Dest) {
            Remove-Item "$Dest.old" -Force -ErrorAction SilentlyContinue
            Rename-Item $Dest "$Dest.old" -ErrorAction SilentlyContinue
        }
        Copy-Item $DlBin $Dest -Force

        $ver = & $Dest --version 2>&1
        Write-Host "-> codebase-memory-mcp: $ver"
    } finally {
        Remove-Item -Recurse -Force $TmpDir -ErrorAction SilentlyContinue
    }
} else {
    Write-Host "-> codebase-memory-mcp: v$CbmVersion already installed"
}

# Ensure the install dir is on the user PATH.
$UserPath = [Environment]::GetEnvironmentVariable('PATH', 'User')
if ($UserPath -notlike "*$InstallDir*") {
    [Environment]::SetEnvironmentVariable('PATH', "$UserPath;$InstallDir", 'User')
    $env:PATH = "$env:PATH;$InstallDir"
    Write-Host "-> codebase-memory-mcp: added $InstallDir to user PATH"
}

# GitKraken MCP -- gk ships its own multi-client installer. `gk mcp install
# --all` detects every installed MCP client and writes a stdio entry that runs
# `gk mcp`. Auth (`gk auth login`) is only needed when the server runs, not to
# write the config, so this is safe non-interactively.
if (Get-Command gk -ErrorAction SilentlyContinue) {
    Write-Host "-> GitKraken MCP: installing into all detected clients..." -ForegroundColor Cyan
    try {
        gk mcp install --all
    } catch {
        Write-Warning "gk mcp install failed: $_"
    }
} else {
    Write-Warning "gk (GitKraken CLI) not found; skipping GitKraken MCP setup."
}

Write-Host ""
Write-Host "Agents outfitted: GitKraken MCP, codebase-memory-mcp binary installed." -ForegroundColor Green
{{- end -}}
