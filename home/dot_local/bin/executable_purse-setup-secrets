#!/usr/bin/env bash
# purse-setup-secrets — pull dotfiles secrets from Zoho Vault into ~/.config/shell/secrets.sh
#
# Usage: purse-setup-secrets
#
# Secrets are stored as custom key/value fields on a single Secure Note in
# Zoho Vault named "PURSE_TOKENS". Add a field there for each env var you want
# exported globally. No local config file needed.
#
# Requires: zv (installed by chezmoi), jq

set -euo pipefail

PURSE_NOTE_NAME="PURSE_TOKENS"
SECRETS_FILE="${HOME}/.config/shell/secrets.sh"

log()  { echo "==> $*"; }
die()  { echo "❌ $*" >&2; exit 1; }
warn() { echo "⚠️  $*" >&2; }

# ── prerequisites ─────────────────────────────────────────────────────────────
command -v zv  >/dev/null 2>&1 || die "zv not found — run: chezmoi apply"
command -v jq  >/dev/null 2>&1 || die "jq not found — install it first"

# ── authentication ─────────────────────────────────────────────────────────────
log "Checking Zoho Vault authentication..."
purse-zv-ensure-auth
log "Authenticated."

# ── fetch PURSE_TOKENS note ────────────────────────────────────────────────────
log "Looking up '${PURSE_NOTE_NAME}' in Zoho Vault..."
search_raw=$(zv search -k "$PURSE_NOTE_NAME" --name --strict --output json 2>/dev/null) \
  || die "zv search failed"

note_id=$(printf '%s' "$search_raw" \
  | jq -re --arg name "$PURSE_NOTE_NAME" \
      '.secrets.secret[] | select(.secretname == $name) | .secretid') \
  || die "Secure Note '${PURSE_NOTE_NAME}' not found in vault"

log "Fetching fields from note id=${note_id}..."
note_raw=$(zv get -id "$note_id" --not-safe --output json 2>/dev/null) \
  || die "Failed to fetch note id=${note_id}"

# ── write secrets file ─────────────────────────────────────────────────────────
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

{
  echo "# ~/.config/shell/secrets.sh"
  echo "# Auto-generated by purse-setup-secrets from Zoho Vault '${PURSE_NOTE_NAME}'"
  echo "# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  echo "# DO NOT EDIT — re-run: purse-setup-secrets"
  echo ""
} > "$tmp"

count=0
while IFS= read -r entry; do
  colname=$(printf '%s' "$entry" | jq -r '.colname')
  value=$(printf '%s' "$entry" | jq -r '.value')
  printf 'export %s=%q\n' "$colname" "$value" >> "$tmp"
  (( count++ )) || true
done < <(printf '%s' "$note_raw" | jq -c '.secret.customcolumn.customcol[]')

install -m 600 "$tmp" "$SECRETS_FILE"
log "Wrote ${count} secret(s) to ${SECRETS_FILE}"
echo ""
echo "  Open a new shell or run: source ${SECRETS_FILE}"
