#!/usr/bin/env bash
# git-wt-add — add a worktree under the umbrella and drop a Tier-B overlay.
#
# Usage:
#   git wt-add <branch> [path]
#   git-wt-add <branch> [path]
#
#   <branch>  Branch to check out. Created from HEAD if it doesn't exist
#             locally; tracked from origin/<branch> if a remote-tracking
#             branch exists.
#   [path]    Worktree path. Default: <umbrella>/<branch>.
#
# Always runs `git wt-overlay` against the new worktree afterwards.

set -euo pipefail

usage() {
  sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-2}"
}

case "${1:-}" in
  -h|--help|"") usage 0 ;;
esac

branch="$1"
target="${2:-}"

# Resolve the umbrella root: the directory whose .git points to a local .bare/.
# Falls back to git's common-dir parent for non-umbrella layouts.
common_dir="$(git rev-parse --git-common-dir)"
common_dir="$(cd "$common_dir" && pwd)"
case "$common_dir" in
  */.bare) umbrella="${common_dir%/.bare}" ;;
  *)       umbrella="$(dirname "$common_dir")" ;;
esac

if [ -z "$target" ]; then
  # Sanitize branch name into a directory-friendly form: replace `/` with `-`.
  target="$umbrella/${branch//\//-}"
fi

# Decide whether to create the branch.
if git -C "$umbrella" show-ref --verify --quiet "refs/heads/$branch"; then
  git -C "$umbrella" worktree add "$target" "$branch"
elif git -C "$umbrella" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
  git -C "$umbrella" worktree add --track -b "$branch" "$target" "origin/$branch"
else
  git -C "$umbrella" worktree add -b "$branch" "$target"
fi

git-wt-overlay "$target"

cat <<EOF
Worktree ready: $target
  cd $target
EOF
