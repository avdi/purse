#!/usr/bin/env bash
# dcsh — open a shell (or run a command) inside the devcontainer for the
# current project.
#
# Usage:
#   dcsh [options] [-- <cmd> [args...]]
#
# Options:
#   -w, --workspace <path>   Workspace folder (default: nearest ancestor with
#                            .devcontainer/ or .devcontainer.json, else cwd).
#   -c, --config <path>      Path to devcontainer.json (required when the
#                            container was started with a non-default config,
#                            e.g. .devcontainer/sidecar/devcontainer.json).
#   -s, --shell <shell>      Shell to launch (default: bash).
#   -u, --user <user>        Remote user to exec as (passed via --remote-env).
#   -h, --help               Show this help.
#
# Anything after -- is passed as the command to exec instead of a shell.
#
# Examples:
#   dcsh                     # bash in the container for this project
#   dcsh -s zsh              # zsh instead
#   dcsh -- rails console    # run a specific command
#   dcsh -w ../other         # target a neighbouring workspace

set -euo pipefail

die() { printf 'dcsh: %s\n' "$*" >&2; exit 1; }

command -v devcontainer >/dev/null 2>&1 || die "'devcontainer' not found on PATH (install @devcontainers/cli)"

# ── defaults ────────────────────────────────────────────────────────────────
workspace=""
config_file=""
shell_cmd="bash"
remote_user=""
extra_cmd=()

# ── argument parsing ─────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -w|--workspace)
      workspace="${2:?--workspace requires a path}"; shift 2 ;;
    -c|--config)
      config_file="${2:?--config requires a path}"; shift 2 ;;
    -s|--shell)
      shell_cmd="${2:?--shell requires a shell name}"; shift 2 ;;
    -u|--user)
      remote_user="${2:?--user requires a username}"; shift 2 ;;
    --)
      shift; extra_cmd=("$@"); break ;;
    -*)
      die "unknown option: $1" ;;
    *)
      die "unexpected argument: $1 (use -- to pass a command)" ;;
  esac
done

# ── locate workspace ─────────────────────────────────────────────────────────
find_workspace() {
  local dir
  dir="$(pwd)"
  while true; do
    if [[ -d "$dir/.devcontainer" || -f "$dir/.devcontainer.json" ]]; then
      echo "$dir"
      return
    fi
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done
  # No marker found — use cwd and let devcontainer CLI report the error.
  pwd
}

if [[ -z "$workspace" ]]; then
  workspace="$(find_workspace)"
fi

# ── locate the running devcontainer ──────────────────────────────────────────
# The devcontainer CLI normally matches containers by deriving a
# `devcontainer.local_folder` label from --workspace-folder. That breaks when
# the container was started by VS Code on Windows against a WSL workspace: the
# label holds a UNC path (\\wsl.localhost\...) while we pass the Linux path, so
# the CLI reports "Dev container not found".
#
# To be robust, find the container id directly and pass it via --container-id,
# which skips local_folder matching entirely. We try the native local_folder
# label first, then fall back to the `devcontainer.config_file` label, which is
# a Linux path under the workspace even for VS Code/WSL containers.
config_label() {
  docker inspect "$1" \
    --format '{{index .Config.Labels "devcontainer.config_file"}}' 2>/dev/null
}

detect_container() {
  local folder="$1" id
  id=$(docker ps -q \
    --filter "label=devcontainer.local_folder=$folder" 2>/dev/null | head -1)
  if [[ -n "$id" ]]; then echo "$id"; return; fi
  for id in $(docker ps -q --filter "label=devcontainer.config_file" 2>/dev/null); do
    [[ "$(config_label "$id")" == "$folder/"* ]] && { echo "$id"; return; }
  done
}

container_id=""
[[ -n "$workspace" ]] && container_id="$(detect_container "$workspace")"

# An explicit --config wins; otherwise derive it from the running container so
# sidecar/non-default configs are picked up automatically.
[[ -z "$config_file" && -n "$container_id" ]] && config_file="$(config_label "$container_id")"

# ── build exec arguments ─────────────────────────────────────────────────────
exec_args=(
  --workspace-folder "$workspace"
  --terminal-columns "$(tput cols 2>/dev/null || echo 220)"
  --terminal-rows    "$(tput lines 2>/dev/null || echo 50)"
)

if [[ -n "$container_id" ]]; then
  exec_args+=(--container-id "$container_id")
  printf 'dcsh: container → %s\n' "$container_id" >&2
fi

if [[ -n "$config_file" ]]; then
  exec_args+=(--config "$config_file")
  printf 'dcsh: config    → %s\n' "$config_file" >&2
fi

[[ -n "$remote_user" ]] && exec_args+=(--remote-env "LOGNAME=$remote_user")

# ── build the command to run inside the container ────────────────────────────
if [[ ${#extra_cmd[@]} -gt 0 ]]; then
  cmd=("${extra_cmd[@]}")
else
  cmd=("$shell_cmd" --login)
fi

printf 'dcsh: workspace → %s\n' "$workspace" >&2
exec devcontainer exec "${exec_args[@]}" "${cmd[@]}"
