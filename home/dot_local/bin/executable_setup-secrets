#!/usr/bin/env bash
# setup-secrets — pull dotfiles secrets from Zoho Vault into ~/.config/shell/secrets.sh
#
# Usage: setup-secrets
#
# Configuration: edit ~/.config/purse/secret-ids.env to map env var names to
# Zoho Vault secret IDs. IDs are non-sensitive numeric identifiers; safe to commit.
# Find an ID: zv search -k "secret-name" --name --output json | jq '.[0]'
#
# Requires: zv (installed by chezmoi), jq

set -euo pipefail

CONFIG_FILE="${HOME}/.config/purse/secret-ids.env"
SECRETS_FILE="${HOME}/.config/shell/secrets.sh"

log()  { echo "==> $*"; }
die()  { echo "❌ $*" >&2; exit 1; }
warn() { echo "⚠️  $*" >&2; }

# ── prerequisites ─────────────────────────────────────────────────────────────
command -v zv  >/dev/null 2>&1 || die "zv not found — run: chezmoi apply"
command -v jq  >/dev/null 2>&1 || die "jq not found — install it first"

# ── authentication ─────────────────────────────────────────────────────────────
log "Checking Zoho Vault authentication..."
if ! zv list category >/dev/null 2>&1; then
  log "Not logged in. Starting interactive login..."
  zv login
fi
log "Authenticated."

# ── config check ──────────────────────────────────────────────────────────────
if [[ ! -f "$CONFIG_FILE" ]]; then
  die "Config not found: ${CONFIG_FILE}\nRun chezmoi apply first, then edit that file."
fi

# Count non-empty, non-comment entries
entries=$(grep -cE '^[A-Z_]+=.+' "$CONFIG_FILE" || true)
if [[ "$entries" -eq 0 ]]; then
  echo ""
  echo "  No secret IDs configured in ${CONFIG_FILE}"
  echo "  To find a secret's numeric ID, run:"
  echo "    zv search -k \"secret-name\" --name --output json | jq '.[0]'"
  echo "  Then add a line to the config:  ENV_VAR_NAME=<numeric-id>"
  echo ""
  die "Populate ${CONFIG_FILE} and re-run."
fi

# ── fetch secrets ──────────────────────────────────────────────────────────────
log "Fetching ${entries} secret(s) from Zoho Vault..."

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

{
  echo "# ~/.config/shell/secrets.sh"
  echo "# Auto-generated by setup-secrets from Zoho Vault"
  echo "# Generated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  echo "# DO NOT EDIT — re-run: setup-secrets"
  echo ""
} > "$tmp"

ok=0
fail=0

while IFS='=' read -r var_name vault_id; do
  [[ -z "$var_name" || "$var_name" =~ ^[[:space:]]*# ]] && continue
  [[ -z "$vault_id" || "$vault_id" == "0" ]] && {
    warn "Skipping ${var_name} — no vault ID set"
    (( fail++ )) || true
    continue
  }

  raw=$(zv get -id "$vault_id" --not-safe --output json 2>/dev/null) || {
    warn "Failed to fetch ${var_name} (id=${vault_id})"
    (( fail++ )) || true
    continue
  }

  value=$(printf '%s' "$raw" | jq -re \
    '.secret.secretData[] | select(.id == "password") | .value' 2>/dev/null) || {
    warn "Could not parse password field for ${var_name} (id=${vault_id})"
    (( fail++ )) || true
    continue
  }

  printf 'export %s=%q\n' "$var_name" "$value" >> "$tmp"
  (( ok++ )) || true

done < <(grep -v '^[[:space:]]*#' "$CONFIG_FILE" | grep -v '^[[:space:]]*$')

# ── write output ───────────────────────────────────────────────────────────────
install -m 600 "$tmp" "$SECRETS_FILE"
log "Wrote ${ok} secret(s) to ${SECRETS_FILE}${fail:+ (${fail} skipped — see warnings above)}"
echo ""
echo "  Open a new shell or run: source ${SECRETS_FILE}"
