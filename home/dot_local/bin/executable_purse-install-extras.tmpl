#!/usr/bin/env bash
# Install optional / environment-specific extras that are too slow or too
# context-sensitive to run inline on every `chezmoi apply`.
#
# chezmoi installs this to ~/.local/bin/purse-install-extras.
# Re-running is safe; each section is idempotent.

set -euo pipefail

# ---- devcontainer-bridge (dbr) ----------------------------------------------
# Enables host-side port forwarding and xdg-open → host browser inside
# devcontainers. The purse devcontainer shim injects the dbr feature into
# every `devcontainer up`; having dbr running on the host activates it.
#
# Project: https://github.com/bradleybeddoes/devcontainer-bridge

if command -v dbr >/dev/null 2>&1; then
  echo "→ dbr already installed ($(dbr --version 2>/dev/null || echo version unknown))"
else
  echo "→ Installing devcontainer-bridge (dbr)..."
  curl -fsSL https://github.com/bradleybeddoes/devcontainer-bridge/releases/latest/download/install.sh | bash
fi

# --host 127.0.0.1 avoids dbr's default host.docker.internal probe, which on
# WSL resolves to the Windows LAN IP and stalls long enough to bust the 5s
# spawn deadline. The daemon still binds 0.0.0.0 so containers reach it via
# host.docker.internal as normal.
echo "→ dbr ensure (start/update host daemon)..."
dbr ensure --host 127.0.0.1

# ---- micro (modern terminal editor; EDITOR fallback) ------------------------
# A single static Go binary — the non-`code` EDITOR fallback wired up in
# env.sh (code --wait → micro → vi). Installed to ~/.local/bin, which env.sh
# puts first on PATH. getmic.ro (the project's official one-line installer)
# auto-detects OS/arch and drops the prebuilt binary into the cwd; no build
# step, no root required.

if command -v micro >/dev/null 2>&1; then
  echo "→ micro already installed ($(micro -version 2>/dev/null | head -1 || echo version unknown))"
else
  echo "→ Installing micro editor to ~/.local/bin..."
  mkdir -p "$HOME/.local/bin"
  ( cd "$HOME/.local/bin" && curl -fsSL https://getmic.ro | bash )
fi

# ---- git 2.48+ (for worktree.useRelativePaths) ------------------------------
# worktree.useRelativePaths sets extensions.relativeworktrees on the repo,
# which older git refuses to parse — so a worktree created by a modern host git
# can't be read by an old container git. This upgrades any git <2.48.
#
#   Ubuntu + apt + root  → inject the git-core PPA key/source directly (no
#                          add-apt-repository, which drags in ~35 heavy deps and
#                          breaks in containers).
#   other apt + root     → build from source with the SYSTEM gcc (Debian's
#                          backports has no newer git, and brew would compile an
#                          entire gcc toolchain first — ~1min from source here
#                          vs. the heat death of the universe via brew).
#   otherwise            → brew (below) provides a current git.

GIT_SOURCE_VERSION="2.51.0"

_git_version_xy() { git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1; }

_git_needs_upgrade() {
  _v="$(_git_version_xy)"; _maj="${_v%%.*}"; _min="${_v##*.}"
  [ -z "$_v" ] || [ "$_maj" -lt 2 ] || { [ "$_maj" -eq 2 ] && [ "$_min" -lt 48 ]; }
}

# Build git from source with the system toolchain, install to /usr/local.
# NO_GETTEXT drops i18n (msgfmt needs libselinux, often broken in slim images);
# NO_TCLTK drops the Tcl/Tk GUI. Neither is needed for CLI/worktree use.
_git_build_from_source() {
  _apt_root apt-get install -y -qq \
    build-essential libz-dev libssl-dev libcurl4-openssl-dev libexpat1-dev
  _tmp="$(mktemp -d)"
  echo "→ git: building ${GIT_SOURCE_VERSION} from source (system gcc) in ${_tmp}..."
  curl -fsSL "https://github.com/git/git/archive/refs/tags/v${GIT_SOURCE_VERSION}.tar.gz" \
    | tar xz -C "$_tmp" --strip-components 1
  make -C "$_tmp" -j"$(nproc)" prefix=/usr/local NO_TCLTK=1 NO_GETTEXT=1 all
  _apt_root make -C "$_tmp" prefix=/usr/local NO_TCLTK=1 NO_GETTEXT=1 install
  rm -rf "$_tmp"
  hash -r
}

if _git_needs_upgrade; then
  _distro_id="$(. /etc/os-release 2>/dev/null && printf '%s' "${ID:-}")"
  _distro_codename="$(. /etc/os-release 2>/dev/null && printf '%s' "${VERSION_CODENAME:-${UBUNTU_CODENAME:-}}")"
  _have_apt_root="$( { command -v apt-get >/dev/null 2>&1 && { [ "$(id -u)" -eq 0 ] || command -v sudo >/dev/null 2>&1; }; } && echo yes || echo no)"
  _apt_root() { [ "$(id -u)" -eq 0 ] && "$@" || sudo "$@"; }
  if [ "$_distro_id" = "ubuntu" ] && [ "$_have_apt_root" = "yes" ] \
      && [ -n "$_distro_codename" ]; then
    echo "→ git: adding git-core PPA for Ubuntu ${_distro_codename}..."
    _apt_root mkdir -p /etc/apt/keyrings
    curl -fsSL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0xE1DD270288B4E6030699E45FA1715D88E1DF1F24" \
      | _apt_root gpg --dearmor -o /etc/apt/keyrings/git-core-ppa.gpg
    printf 'deb [signed-by=/etc/apt/keyrings/git-core-ppa.gpg] https://ppa.launchpadcontent.net/git-core/ppa/ubuntu %s main\n' \
      "$_distro_codename" \
      | _apt_root tee /etc/apt/sources.list.d/git-core-ppa.list > /dev/null
    _apt_root apt-get update -qq
    _apt_root apt-get install -y git
  elif [ "$_have_apt_root" = "yes" ]; then
    _git_build_from_source
    echo "→ git: now $(_git_version_xy) (built from source)"
  else
    echo "→ git: no apt/root — brew will provide git 2.48+ below"
  fi
else
  echo "→ git: $(_git_version_xy) already ≥2.48"
fi

# ---- Homebrew toolset -------------------------------------------------------
# Homebrew is only used where it's the sole option:
#
#   macOS           → full brew list (brew is the only package manager)
#   Linux, no root  → full brew list (apt can't be used at all)
#   Linux, apt+root → skipped entirely. apt/NodeSource/GitHub-releases cover the
#                     whole toolset (yq ships as a prebuilt release binary via
#                     run_onchange_install-packages.sh, worktrunk and gk via
#                     their own run_onchange scripts), and git was handled above
#                     (PPA or from source).
#
# A home-dir brew prefix (~/.homebrew) can't use pre-built bottles, so
# everything builds from source — hence we only fall back to it when apt is
# unavailable, never to install a single formula.
#
# brew packages (macOS / Linux no-root): {{ .packages.brew | join ", " }}

find_brew() {
  if command -v brew >/dev/null 2>&1; then command -v brew; return; fi
  for _b in "$HOME/.homebrew/bin/brew" /home/linuxbrew/.linuxbrew/bin/brew \
            /opt/homebrew/bin/brew /usr/local/bin/brew; do
    [ -x "$_b" ] && { echo "$_b"; return; }
  done
  return 1
}

if [ "$(uname)" = "Darwin" ] \
    || ! { command -v apt-get >/dev/null 2>&1 \
           && { [ "$(id -u)" -eq 0 ] || command -v sudo >/dev/null 2>&1; }; }; then
  brew_bin="$(find_brew || true)"
  if [ -z "$brew_bin" ]; then
    echo "→ Homebrew not found; installing to ~/.homebrew (no root required)..."
    echo "   Heads up: a home-dir prefix can't use bottles, so formulae build"
    echo "   from source — this can take a long while."
    mkdir -p "$HOME/.homebrew"
    curl -fsSL https://github.com/Homebrew/brew/tarball/master \
      | tar xz --strip-components 1 -C "$HOME/.homebrew"
    brew_bin="$HOME/.homebrew/bin/brew"
    eval "$("$brew_bin" shellenv)"
    brew update --force --quiet
  else
    echo "→ Using existing Homebrew: $brew_bin"
    eval "$("$brew_bin" shellenv)"
  fi
  echo "→ brew: {{ .packages.brew | join ", " }}"
  brew install {{ .packages.brew | join " " }}
else
  echo "→ brew: skipped (Linux with apt — toolset covered by apt/GitHub releases)"
fi

cat <<'EOF'

✅ Extras installed.

Next steps:
  • Open a new shell so Homebrew tools land on PATH (env.sh wires ~/.homebrew /
    linuxbrew automatically), or run: eval "$(brew shellenv)"
  • Run `purse-install-agents` to install the npm-based AI agent CLIs.
  • Then run `purse-outfit-agents` to wire up MCP servers, agent plugins,
    spec-kit, the GitKraken MCP server, and codebase-memory-mcp.

EOF
