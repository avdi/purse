#!/usr/bin/env bash
# purse-get-secret-id — find a Zoho Vault numeric ID by env var name
#
# Usage: purse-get-secret-id ENV_VAR_NAME
#
# Searches Zoho Vault for a secret whose title exactly matches ENV_VAR_NAME
# and prints its numeric ID. Useful for populating ~/.config/purse/secret-ids.env.
#
# Requires: zv, jq

set -euo pipefail

var_name="${1:?Usage: purse-get-secret-id ENV_VAR_NAME}"

command -v zv >/dev/null 2>&1 || { echo "zv not found — run: chezmoi apply" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "jq not found" >&2; exit 1; }

purse-zv-ensure-auth

raw=$(zv search -k "$var_name" --name --strict --output json 2>/dev/null) \
  || { echo "zv search failed" >&2; exit 1; }

id=$(printf '%s' "$raw" \
  | jq -re --arg name "$var_name" \
      '.secrets.secret[] | select(.secretname == $name) | .secretid' 2>/dev/null) \
  || { echo "No secret found named: ${var_name}" >&2; exit 1; }

echo "$id"
