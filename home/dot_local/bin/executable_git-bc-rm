#!/usr/bin/env bash
# git-bc-rm — safely remove a branch clone created by git-bc-add.
#
# Usage:
#   git bc-rm <clone-dir> [--force]
#   git-bc-rm <clone-dir> [--force]
#
#   <clone-dir>  Path to the branch clone to remove.
#   --force      Remove even if the working tree is dirty or has unpushed
#                commits on the checked-out branch.

set -euo pipefail

usage() {
  sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-2}"
}

clone_dir=""
force=false

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)   usage 0 ;;
    --force|-f)  force=true ;;
    *) if [ -z "$clone_dir" ]; then clone_dir="$1"; else usage 2; fi ;;
  esac
  shift
done

[ -n "$clone_dir" ] || usage 2

if [ ! -d "$clone_dir" ]; then
  echo "git-bc-rm: not a directory: $clone_dir" >&2
  exit 1
fi

if ! git -C "$clone_dir" rev-parse --git-dir >/dev/null 2>&1; then
  echo "git-bc-rm: not a git repository: $clone_dir" >&2
  exit 1
fi

if ! $force; then
  # Dirty working tree?
  if ! git -C "$clone_dir" diff --quiet 2>/dev/null \
      || ! git -C "$clone_dir" diff --cached --quiet 2>/dev/null; then
    echo "git-bc-rm: $clone_dir has uncommitted changes (use --force to override)" >&2
    exit 1
  fi

  # Unpushed commits on current branch?
  branch="$(git -C "$clone_dir" symbolic-ref --short HEAD 2>/dev/null || true)"
  if [ -n "$branch" ]; then
    upstream="$(git -C "$clone_dir" rev-parse --abbrev-ref "@{upstream}" 2>/dev/null || true)"
    if [ -n "$upstream" ]; then
      ahead="$(git -C "$clone_dir" rev-list --count "$upstream..HEAD" 2>/dev/null || echo 0)"
      if [ "$ahead" -gt 0 ]; then
        echo "git-bc-rm: $clone_dir has $ahead unpushed commit(s) on '$branch' (use --force to override)" >&2
        exit 1
      fi
    elif git -C "$clone_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      ahead="$(git -C "$clone_dir" rev-list --count "origin/$branch..HEAD" 2>/dev/null || echo 0)"
      if [ "$ahead" -gt 0 ]; then
        echo "git-bc-rm: $clone_dir has $ahead unpushed commit(s) on '$branch' (use --force to override)" >&2
        exit 1
      fi
    else
      echo "git-bc-rm: branch '$branch' in $clone_dir has no upstream (use --force to override)" >&2
      exit 1
    fi
  fi
fi

abs="$(cd "$clone_dir" && pwd)"
rm -rf "$abs"
echo "Removed branch clone: $abs"
