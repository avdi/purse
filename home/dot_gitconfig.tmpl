[user]
	email = avdi@avdi.codes
	name = Avdi Grimm
	signingkey = 2EFC2BD07E026325
[gpg]
	program = gpg
[commit]
	gpgsign = false
[tag]
	forceSignAnnotated = false
[init]
	defaultBranch = main
[alias]
	# Bare-umbrella worktree workflow. Each command is also directly
	# invocable on PATH (git-clone-bare, git-wt-add, etc.); these aliases
	# exist mainly so `git config --get-regexp alias` advertises them.
	clone-bare = "!git-clone-bare"
	wt-add     = "!git-wt-add"
	wt-rm      = "!git-wt-rm"
	wt-repair  = "!git-wt-repair"
	wt-overlay = "!git-wt-overlay"
[extensions]
	worktreeConfig = true
[worktree]
	useRelativePaths = true
[gpg "ssh"]
	program = ssh-keygen
	allowedSignersFile = ""
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
{{/*
  Only emit the Git-for-Windows credential helper in *real* WSL2 user-space.
  The kernel osrelease string contains "microsoft" for any Linux running on
  a WSL2 kernel — including containers under Docker Desktop on Windows, which
  share the host kernel but have no /mnt/c/. Requiring /mnt/c/Windows to exist
  distinguishes real WSL user-space from a WSL2-kernel-hosted container.

  The outer linux guard is required: .chezmoi.kernel is sourced from
  /proc/sys/kernel and is an empty map on Windows/macOS, so referencing
  .chezmoi.kernel.osrelease unconditionally errors there ("map has no entry
  for key 'osrelease'"). Go templates evaluate all args of `and` eagerly, so
  the OS check must be nested rather than inlined.
*/ -}}
{{- if eq .chezmoi.os "linux" -}}
{{- if and (contains "microsoft" .chezmoi.kernel.osrelease) (stat "/mnt/c/Windows") }}
[credential]
	helper = /mnt/c/Program\\ Files/Git/mingw64/bin/git-credential-manager.exe
{{- end }}
{{- end }}
