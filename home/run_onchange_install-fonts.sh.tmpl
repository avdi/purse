{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_onchange: install Cascadia Code NF
#
# Downloads directly from microsoft/cascadia-code GitHub releases, which
# ships NF variants officially (no third-party repackaging).
# Installs only the NF TTFs into the user font directory.
#
# Re-runs whenever this script changes (e.g. to bump the font version).
# Font version: 2407.24
set -euo pipefail

FONT_VERSION="2407.24"
FONT_ARCHIVE="CascadiaCode-${FONT_VERSION}.zip"
DOWNLOAD_URL="https://github.com/microsoft/cascadia-code/releases/download/v${FONT_VERSION}/${FONT_ARCHIVE}"

case "$(uname)" in
  Darwin) FONT_DIR="$HOME/Library/Fonts" ;;
  *)      FONT_DIR="$HOME/.local/share/fonts" ;;
esac

if find "$FONT_DIR" -name "CascadiaCodeNF-Regular.ttf" 2>/dev/null | grep -q .; then
  echo "→ Cascadia Code NF already installed in $FONT_DIR"
  exit 0
fi

echo "→ Installing Cascadia Code NF v${FONT_VERSION} from microsoft/cascadia-code..."
mkdir -p "$FONT_DIR"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

curl -fsSL -o "$TMP_DIR/$FONT_ARCHIVE" "$DOWNLOAD_URL"
# Extract only the NF TTFs (ttf/static/CascadiaCodeNF-*.ttf) directly into FONT_DIR
unzip -j -o "$TMP_DIR/$FONT_ARCHIVE" 'ttf/static/CascadiaCodeNF-*.ttf' -d "$FONT_DIR"

if command -v fc-cache >/dev/null 2>&1; then
  fc-cache -f "$FONT_DIR"
fi

echo "✓ Cascadia Code NF installed"
{{- end }}
