{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_onchange: install codebase-memory-mcp and configure all agents.
#
# codebase-memory-mcp is a single static binary that ships its own multi-agent
# installer: `codebase-memory-mcp install -y` auto-detects every installed
# coding agent (Claude Code, Codex, Gemini CLI, Zed, OpenCode, Antigravity,
# Aider, KiloCode, VS Code, ...) and wires up the MCP entry, instruction
# files, and pre-tool hooks for each. Unlike the npx-style servers in
# .chezmoidata/mcp-servers.yaml, this one is deliberately NOT registered
# per-agent by run_onchange_install-mcp-servers.sh.tmpl — the binary owns its
# own configuration.
#
# Bump CBM_VERSION to trigger a reinstall (this run_onchange script re-runs
# whenever its rendered content changes).
#
# Linux uses the fully-static "-portable" asset; the standard linux build
# dynamically links glibc 2.38+ and breaks on older distros. macOS has no
# portable variant.

set -euo pipefail

REPO="DeusData/codebase-memory-mcp"
CBM_VERSION="0.8.1"
INSTALL_DIR="$HOME/.local/bin"
BINARY="$INSTALL_DIR/codebase-memory-mcp"

mkdir -p "$INSTALL_DIR"

_installed_ver() {
  command -v codebase-memory-mcp >/dev/null 2>&1 || { echo "none"; return; }
  codebase-memory-mcp --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1
}

if [ "$(_installed_ver)" != "$CBM_VERSION" ]; then
  echo "→ codebase-memory-mcp: installing v${CBM_VERSION}..."

  case "$(uname -s)" in
    Darwin) _os="darwin" ;;
    Linux)  _os="linux"  ;;
    *) echo "⚠️  codebase-memory-mcp: unsupported OS $(uname -s)" >&2; exit 1 ;;
  esac

  _arch="$(uname -m)"
  case "$_arch" in
    arm64|aarch64) _cbm_arch="arm64" ;;
    x86_64|amd64)
      # macOS reports x86_64 under Rosetta even on Apple Silicon.
      if [ "$_os" = "darwin" ] && sysctl -n machdep.cpu.brand_string 2>/dev/null | grep -qi apple; then
        _cbm_arch="arm64"
      else
        _cbm_arch="amd64"
      fi
      ;;
    *) echo "⚠️  codebase-memory-mcp: unsupported arch $_arch" >&2; exit 1 ;;
  esac

  _portable=""
  [ "$_os" = "linux" ] && _portable="-portable"

  _asset="codebase-memory-mcp-${_os}-${_cbm_arch}${_portable}.tar.gz"
  _base="https://github.com/${REPO}/releases/download/v${CBM_VERSION}"

  _tmpdir="$(mktemp -d)"
  trap 'rm -rf "$_tmpdir"' EXIT

  curl -fsSL -o "$_tmpdir/$_asset" "${_base}/${_asset}"

  # Verify checksum when the list is reachable (non-fatal if it isn't).
  if curl -fsSL -o "$_tmpdir/checksums.txt" "${_base}/checksums.txt" 2>/dev/null; then
    _expected="$(grep "$_asset" "$_tmpdir/checksums.txt" 2>/dev/null | awk '{print $1}')" || true
    if [ -n "${_expected:-}" ]; then
      if command -v sha256sum >/dev/null 2>&1; then
        _actual="$(sha256sum "$_tmpdir/$_asset" | awk '{print $1}')"
      elif command -v shasum >/dev/null 2>&1; then
        _actual="$(shasum -a 256 "$_tmpdir/$_asset" | awk '{print $1}')"
      else
        _actual=""
      fi
      if [ -n "$_actual" ] && [ "$_expected" != "$_actual" ]; then
        echo "⚠️  codebase-memory-mcp: checksum mismatch — aborting" >&2
        echo "    expected: $_expected" >&2
        echo "    actual:   $_actual" >&2
        exit 1
      fi
    fi
  fi

  tar -xzf "$_tmpdir/$_asset" -C "$_tmpdir"
  install -m755 "$_tmpdir/codebase-memory-mcp" "$BINARY"

  if [ "$_os" = "darwin" ]; then
    xattr -d com.apple.quarantine "$BINARY" 2>/dev/null || true
    codesign --sign - --force "$BINARY" 2>/dev/null || true
  fi

  echo "→ codebase-memory-mcp: $("$BINARY" --version 2>&1)"
else
  echo "→ codebase-memory-mcp: v${CBM_VERSION} already installed"
fi

# Auto-configure every installed agent. Idempotent; -y = non-interactive.
echo "→ codebase-memory-mcp: configuring agents..."
"$BINARY" install -y
{{- end }}
