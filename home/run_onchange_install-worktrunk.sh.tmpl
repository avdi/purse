{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_onchange: install worktrunk and configure shell integration.
#
# On all Unix (Linux and macOS) worktrunk is a prebuilt Rust binary downloaded
# directly to ~/.local/bin/ so no root access is needed — brew would otherwise
# source-build its entire toolchain in a home-dir prefix. Update WT_VERSION
# below to trigger a reinstall.
#
# Shell integration (`wt config shell install`) is idempotent — it adds a
# single eval line to rc files and skips if already present.

set -euo pipefail

WT_VERSION="0.62.0"

_installed_ver() {
  command -v wt >/dev/null 2>&1 || { echo "none"; return; }
  wt --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1
}

if [ "$(_installed_ver)" != "$WT_VERSION" ]; then
  echo "→ worktrunk: installing v${WT_VERSION}..."
  case "$(uname -s)-$(uname -m)" in
    Linux-x86_64)                 _wt_target="x86_64-unknown-linux-musl" ;;
    Linux-aarch64)                _wt_target="aarch64-unknown-linux-musl" ;;
    Darwin-x86_64)                _wt_target="x86_64-apple-darwin" ;;
    Darwin-arm64|Darwin-aarch64)  _wt_target="aarch64-apple-darwin" ;;
    *) echo "⚠️  worktrunk: unsupported platform $(uname -s)/$(uname -m)" >&2; exit 1 ;;
  esac
  _tmpdir="$(mktemp -d)"
  trap 'rm -rf "$_tmpdir"' EXIT
  curl -fsSL \
    "https://github.com/max-sixty/worktrunk/releases/download/v${WT_VERSION}/worktrunk-${_wt_target}.tar.xz" \
    | tar -xJ -C "$_tmpdir"
  install -m755 "$_tmpdir/worktrunk-${_wt_target}/wt"     "$HOME/.local/bin/wt"
  install -m755 "$_tmpdir/worktrunk-${_wt_target}/git-wt" "$HOME/.local/bin/git-wt"
  echo "→ worktrunk: v${WT_VERSION} installed to ~/.local/bin/"
else
  echo "→ worktrunk: v${WT_VERSION} already installed"
fi

echo "→ worktrunk: configuring shell integration..."
wt config shell install --yes
{{- end }}
