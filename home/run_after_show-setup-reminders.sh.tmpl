{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_after: remind me of the manual setup steps that `chezmoi apply`
# deliberately does NOT run — they're too slow, need network, or hinge on a
# root/no-root decision. Runs on every apply; purely informational, never fails.

set -uo pipefail

# Only nag at an interactive terminal — stay silent in CI, Codespaces/devcontainer
# bootstrap, cron, etc.
[ -t 1 ] || exit 0

have() { command -v "$1" >/dev/null 2>&1; }

# A bullet is shown for every command; the trailing note adapts to current state
# so a fully-set-up machine reads as "nothing left to do".
note_tools=""
if [ "$(uname)" = "Linux" ] && ! have brew \
   && [ ! -x "$HOME/.homebrew/bin/brew" ] && [ ! -x /home/linuxbrew/.linuxbrew/bin/brew ] \
   && ! { [ "$(id -u)" = "0" ] || have sudo; }; then
  note_tools="  ← no root + no brew detected"
fi

agents_present=0
for _a in claude codex cursor-agent devin auggie agy opencode; do
  have "$_a" && { agents_present=1; break; }
done
note_agents=""
[ "$agents_present" -eq 0 ] && note_agents="  ← no agent CLIs detected"

note_outfit=""
have codebase-memory-mcp || note_outfit="  ← codebase-memory-mcp not installed"

note_extras=""
have dbr || note_extras="  ← dbr not installed"

cat <<EOF

── purse: manual setup commands (not run by \`chezmoi apply\`) ──
  • purse-install-tools    Homebrew + full toolset, no root needed${note_tools}
  • purse-install-agents   AI agent CLIs (claude, codex, cursor, devin, auggie, agy, opencode)${note_agents}
  • purse-outfit-agents    MCP servers + Claude plugins + GitKraken MCP + codebase-memory-mcp${note_outfit}
  • purse-install-extras   host-side devcontainer-bridge (dbr)${note_extras}

EOF

exit 0
{{- end -}}
