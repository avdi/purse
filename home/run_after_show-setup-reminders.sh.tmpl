{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_after: remind me of the manual setup steps that `chezmoi apply`
# deliberately does NOT run — they're too slow, need network, or hinge on a
# root/no-root decision. Runs on every apply; purely informational, never fails.

set -uo pipefail

# Only nag at an interactive terminal — stay silent in CI, Codespaces/devcontainer
# bootstrap, cron, etc.
[ -t 1 ] || exit 0

have() { command -v "$1" >/dev/null 2>&1; }

# A bullet is shown for every command; the trailing note adapts to current state
# so a fully-set-up machine reads as "nothing left to do".
agents_present=0
for _a in claude codex cursor-agent devin auggie agy opencode; do
  have "$_a" && { agents_present=1; break; }
done
note_agents=""
[ "$agents_present" -eq 0 ] && note_agents="  ← no agent CLIs detected"

note_outfit=""
have codebase-memory-mcp || note_outfit="  ← codebase-memory-mcp not installed"

# Cheap auth probes only (skip auggie's slow `token print`): flag the common
# breakages — gh not logged in, github MCP token missing.
note_auth=""
_auth_need=""
have gh && ! gh auth token >/dev/null 2>&1 && _auth_need="gh"
[ -r "$HOME/.config/shell/secrets.sh" ] && . "$HOME/.config/shell/secrets.sh"
[ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ] && _auth_need="${_auth_need:+${_auth_need}, }github token"
[ -n "$_auth_need" ] && note_auth="  ← ${_auth_need} not set"

note_extras=""
have dbr || note_extras="dbr not installed"
_git_v="$(git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)"
_git_maj="${_git_v%%.*}"; _git_min="${_git_v##*.}"
if [ -z "$_git_v" ] || [ "$_git_maj" -lt 2 ] || { [ "$_git_maj" -eq 2 ] && [ "$_git_min" -lt 48 ]; }; then
  note_extras="${note_extras:+${note_extras}; }git ${_git_v:-none} < 2.48"
fi
[ -n "$note_extras" ] && note_extras="  ← ${note_extras}"

cat <<EOF

── purse: manual setup commands (not run by \`chezmoi apply\`) ──
  • purse-install-extras   Homebrew + full toolset (no root needed) + devcontainer-bridge (dbr)${note_extras}
  • purse-install-agents   AI agent CLIs (claude, codex, cursor, devin, auggie, agy, opencode)${note_agents}
  • purse-outfit-agents    MCP servers + agent plugins + GitKraken MCP + codebase-memory-mcp${note_outfit}
  • purse-auth-tools       Verify/remediate logins: gh, gk, auggie, MCP tokens${note_auth}

EOF

exit 0
{{- end -}}
