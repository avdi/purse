# ~/.local/share/chezmoi/home/.chezmoiignore
# Files that chezmoi should not manage (not tracked in source state).

# Generated by setup-secrets — contains plaintext secrets, never committed
.config/shell/secrets.sh

# ~/.gitconfig is a thin, unmanaged stub (created once by
# run_once_setup-gitconfig-stub). The real, managed git config lives at
# ~/.config/git/config (XDG). Leaving the stub unmanaged means runtime
# mutations — notably VS Code's injected credential.helper — never dirty a
# chezmoi-tracked file.
.gitconfig
