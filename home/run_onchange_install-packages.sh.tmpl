{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
# chezmoi run_onchange: install packages (Unix/Linux/macOS)
#
# Package lists are baked in from .chezmoidata/packages.yaml by the template
# engine. Adding or removing a package changes this script's rendered content,
# which causes chezmoi to re-run it on the next apply.
#
# Windows is handled by run_onchange_install-packages.ps1.tmpl instead.
# On Windows this template renders empty so chezmoi skips execution entirely
# (chezmoi can't fork/exec a .sh on Windows — it errors with "%1 is not a
# valid Win32 application").
#
# brew packages  : {{ .packages.brew | join ", " }}
# apt packages   : {{ .packages.apt  | join ", " }}
set -euo pipefail
mkdir -p "$HOME/.local/bin"

# ---- helpers ----------------------------------------------------------------

node_major() {
  command -v node >/dev/null 2>&1 || { echo 0; return; }
  node -e 'process.stdout.write(process.version.slice(1).split(".")[0])'
}

# Run a command with root privileges. No-op wrapper when already root (common in
# devcontainers, where sudo may be absent); uses sudo otherwise. Only ever
# called when something actually needs installing, so a non-interactive apply
# stays quiet as long as everything is already present.
as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    echo "⚠️  root privileges required but sudo is unavailable: $*" >&2
    return 1
  fi
}

# True when we can install system packages: already root, or sudo is available.
have_root() {
  [ "$(id -u)" -eq 0 ] || command -v sudo >/dev/null 2>&1
}

# ---- bootstrap Homebrew (macOS only) ----------------------------------------
# On Linux we use apt + GitHub releases directly, so we don't auto-install brew.
# Brew may already be present on Linux (e.g. for a newer git) and that's fine —
# we just don't install our listed packages through it.

if [ "$(uname)" = "Darwin" ] && ! command -v brew >/dev/null 2>&1; then
  echo "→ Homebrew not found on macOS; installing..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# ---- system packages ---------------------------------------------------------
# Strategy:
#   macOS  → Homebrew for everything (brew list used as-is)
#   Linux  → apt for apt packages; NodeSource for Node; GitHub releases for
#             the rest.  Brew may be present on Linux (e.g. for a newer git)
#             but we deliberately avoid using it for our listed packages to
#             prevent heavy dependency trees (node pulls in python, etc.).

if [ "$(uname)" = "Darwin" ]; then
  # ---- macOS: Homebrew -------------------------------------------------------
  if ! command -v brew >/dev/null 2>&1; then
    echo "⚠️  Homebrew not found on macOS" >&2
    exit 1
  fi
  echo "→ brew (macOS): {{ .packages.brew | join ", " }}"
  brew install {{ .packages.brew | join " " }}

elif command -v apt-get >/dev/null 2>&1 && have_root; then
  # ---- Linux: apt + GitHub releases (preferred over brew) -------------------
  # Only touch apt (and therefore sudo) when a package is actually missing.
  # Keeps non-interactive applies clean and avoids needless password prompts
  # when everything is already installed.
  _apt_missing=()
  for _pkg in {{ .packages.apt | join " " }}; do
    dpkg -s "$_pkg" >/dev/null 2>&1 || _apt_missing+=("$_pkg")
  done
  if [ "${#_apt_missing[@]}" -gt 0 ]; then
    echo "→ apt: installing ${_apt_missing[*]}"
    as_root apt-get update -qq
    as_root apt-get install -y --no-install-recommends "${_apt_missing[@]}"
  else
    echo "→ apt: already installed ({{ .packages.apt | join ", " }})"
  fi

  # git 2.48+ — required for worktree.useRelativePaths (introduced in 2.48.0).
  # We're already in the root-capable branch, so upgrade via the git-core PPA.
  _git_cur="$(git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)"
  _git_major="${_git_cur%%.*}"
  _git_minor="${_git_cur##*.}"
  if [ -z "$_git_cur" ] || [ "$_git_major" -lt 2 ] || { [ "$_git_major" -eq 2 ] && [ "$_git_minor" -lt 48 ]; }; then
    echo "→ git: ${_git_cur:-none} is too old (need ≥2.48); upgrading via git-core PPA..."
    if ! command -v add-apt-repository >/dev/null 2>&1; then
      as_root apt-get install -y --no-install-recommends software-properties-common
    fi
    as_root add-apt-repository -y ppa:git-core/ppa
    as_root apt-get update -qq
    as_root apt-get install -y git
  else
    echo "→ git: $(git --version) already ≥2.48, skipping"
  fi

  # Node.js 22+ — use system node if already ≥22, otherwise NodeSource
  if [ "$(node_major)" -lt 22 ]; then
    echo "→ Node.js 22+ required; installing via NodeSource..."
    curl -fsSL https://deb.nodesource.com/setup_22.x | as_root bash -
    as_root apt-get install -y nodejs
  else
    echo "→ Node.js $(node --version) already installed (system), skipping"
  fi


  # vscli: install binary from GitHub releases
  if ! command -v vscli >/dev/null 2>&1; then
    echo "→ vscli: installing from GitHub releases..."
    _arch="$(uname -m)"
    case "$_arch" in
      x86_64)  _vscli_arch="x86_64-unknown-linux-musl" ;;
      aarch64) _vscli_arch="arm-unknown-linux-gnueabihf" ;;
      *)        echo "⚠️  vscli: unsupported arch $_arch"; _vscli_arch="" ;;
    esac
    if [ -n "$_vscli_arch" ]; then
      _vscli_ver="$(curl -fsSL https://api.github.com/repos/michidk/vscli/releases/latest | grep '"tag_name"' | cut -d'"' -f4)"
      curl -fsSL "https://github.com/michidk/vscli/releases/download/${_vscli_ver}/vscli-${_vscli_arch}.tar.gz" \
        | tar -xz --strip-components=1 -C "$HOME/.local/bin" "vscli-${_vscli_arch}/vscli"
      chmod +x "$HOME/.local/bin/vscli"
    fi
  fi

  # uv: fast Python package manager and tool runner (not in apt — use the official installer)
  if ! command -v uv >/dev/null 2>&1; then
    echo "→ uv: installing via official installer..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
  fi

  # chruby: install from source via make (not in apt)
  # See: https://github.com/postmodern/chruby#install
  if [ ! -f /usr/local/share/chruby/chruby.sh ]; then
    echo "→ chruby: installing from source..."
    _chruby_ver="$(curl -fsSL https://api.github.com/repos/postmodern/chruby/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')"
    curl -fsSL "https://github.com/postmodern/chruby/archive/v${_chruby_ver}.tar.gz" | tar -xz -C /tmp
    as_root make -C "/tmp/chruby-${_chruby_ver}" install
    rm -rf "/tmp/chruby-${_chruby_ver}"
  fi

  # ruby-install: install from source via make (not in apt)
  # See: https://github.com/postmodern/ruby-install#install
  if ! command -v ruby-install >/dev/null 2>&1; then
    echo "→ ruby-install: installing from source..."
    _ri_ver="$(curl -fsSL https://api.github.com/repos/postmodern/ruby-install/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')"
    curl -fsSL "https://github.com/postmodern/ruby-install/archive/v${_ri_ver}.tar.gz" | tar -xz -C /tmp
    as_root make -C "/tmp/ruby-install-${_ri_ver}" install
    rm -rf "/tmp/ruby-install-${_ri_ver}"
  fi

else
  if [ "$(uname)" = "Linux" ]; then
    cat >&2 <<'EOF'
⚠️  No root/sudo on this Linux system — skipping system package installation.
   git ≥2.48 (for worktree.useRelativePaths) and the rest of the toolset can't
   be installed via apt here. Install them into your home directory with:

       purse-install-extras

   That installs Homebrew locally (if needed) and the full brew toolset.
EOF
  else
    echo "⚠️  No supported package manager found (need brew on macOS or apt-get on Linux)" >&2
    exit 1
  fi
fi


# ---- npm core tools (e.g. devcontainer) -------------------------------------
# These are "basic" tools installed whenever Node.js 22+ is present.
# Uses ~/.local prefix to avoid needing root/sudo.
if [ "$(node_major)" -ge 22 ]; then
  echo "→ npm core: {{ .packages.npm | join ", " }}"
  npm config set prefix "$HOME/.local"
  npm install -g {{ .packages.npm | join " " }}
fi

# ---- spec-kit (specify CLI) -------------------------------------------------
# Spec-Driven Development toolkit — installed as a uv tool.

if command -v uv >/dev/null 2>&1; then
  echo "→ spec-kit: installing/upgrading via uv tool..."
  # --link-mode=copy: in devcontainers the uv cache and ~/.local/share/uv
  # often sit on different filesystems (named Docker volume), so hardlinking
  # fails and uv warns before falling back to copy. Copy directly to stay quiet.
  uv tool install --force --link-mode=copy specify-cli --from git+https://github.com/github/spec-kit.git
else
  echo "⚠️  uv not found — skipping spec-kit install (re-run chezmoi apply after uv is on PATH)" >&2
fi

# ---- gk (GitKraken CLI) -----------------------------------------------------
# Not in apt, and brew ships it as a macOS-only cask, so install the release
# binary from GitHub into ~/.local/bin on every Unix host (root or not).
# `gk mcp install --all` (run by purse-outfit-agents) registers its MCP server.
if ! command -v gk >/dev/null 2>&1; then
  if command -v unzip >/dev/null 2>&1; then
    case "$(uname -s)" in
      Darwin) _gk_os="darwin" ;;
      Linux)  _gk_os="linux"  ;;
      *)      _gk_os="" ;;
    esac
    case "$(uname -m)" in
      x86_64|amd64)  _gk_arch="amd64" ;;
      arm64|aarch64) _gk_arch="arm64" ;;
      *)             _gk_arch="" ;;
    esac
    if [ -n "$_gk_os" ] && [ -n "$_gk_arch" ]; then
      echo "→ gk: installing GitKraken CLI from GitHub releases..."
      _gk_ver="$(curl -fsSL https://api.github.com/repos/gitkraken/gk-cli/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')"
      _gk_tmp="$(mktemp -d)"
      if curl -fsSL -o "$_gk_tmp/gk.zip" \
          "https://github.com/gitkraken/gk-cli/releases/download/v${_gk_ver}/gk_${_gk_ver}_${_gk_os}_${_gk_arch}.zip"; then
        unzip -q -o "$_gk_tmp/gk.zip" gk -d "$HOME/.local/bin"
        chmod +x "$HOME/.local/bin/gk"
      else
        echo "⚠️  gk: download failed (gk_${_gk_ver}_${_gk_os}_${_gk_arch}.zip)" >&2
      fi
      rm -rf "$_gk_tmp"
    else
      echo "⚠️  gk: unsupported platform $(uname -s)/$(uname -m) — skipping" >&2
    fi
  else
    echo "⚠️  gk: unzip not found — skipping GitKraken CLI install" >&2
  fi
fi
{{- end }}
