{{- if eq .chezmoi.os "windows" -}}
# chezmoi run_onchange: install Cascadia Code NF (Nerd Font) — Windows
#
# Downloads CaskaydiaCove NF from the Nerd Fonts GitHub releases and installs
# it per-user (no admin required) into %LOCALAPPDATA%\Microsoft\Windows\Fonts,
# then registers each font in HKCU so Windows recognises it immediately.
#
# Re-runs whenever this script changes (e.g. to bump the font version).
# Font version: 3.4.0
$ErrorActionPreference = 'Stop'

$FontVersion  = '3.4.0'
$FontName     = 'CascadiaCode'
$ArchiveName  = "$FontName.tar.xz"
$DownloadUrl  = "https://github.com/ryanoasis/nerd-fonts/releases/download/v$FontVersion/$ArchiveName"
$FontDir      = "$env:LOCALAPPDATA\Microsoft\Windows\Fonts"
$RegPath      = 'HKCU:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts'

# Already installed?
if (Test-Path "$FontDir\CaskaydiaCoveNerdFont-Regular.ttf") {
    Write-Host "→ Cascadia Code NF already installed in $FontDir"
    exit 0
}

Write-Host "→ Installing Cascadia Code NF v$FontVersion..." -ForegroundColor Cyan

if (-not (Test-Path $FontDir)) {
    New-Item -ItemType Directory -Path $FontDir -Force | Out-Null
}

$TmpDir = Join-Path $env:TEMP "nerd-fonts-$FontVersion"
New-Item -ItemType Directory -Path $TmpDir -Force | Out-Null

try {
    $ArchivePath = Join-Path $TmpDir $ArchiveName
    Write-Host "  Downloading $DownloadUrl..."
    Invoke-WebRequest -Uri $DownloadUrl -OutFile $ArchivePath -UseBasicParsing

    # tar is built into Windows 10 1803+ and handles .tar.xz natively
    Write-Host "  Extracting TTF files..."
    & tar -xJf $ArchivePath -C $TmpDir --wildcards '*.ttf' 2>$null
    if ($LASTEXITCODE -ne 0) {
        & tar -xJf $ArchivePath -C $TmpDir
    }

    # Copy TTFs to font dir and register each one
    $ttfs = Get-ChildItem -Path $TmpDir -Filter '*.ttf' -Recurse
    foreach ($ttf in $ttfs) {
        $dest = Join-Path $FontDir $ttf.Name
        Copy-Item -Path $ttf.FullName -Destination $dest -Force
        # Register in HKCU so GDI and DirectWrite pick it up without rebooting
        $regName = $ttf.BaseName + ' (TrueType)'
        Set-ItemProperty -Path $RegPath -Name $regName -Value $ttf.Name -Force
    }

    Write-Host "✓ Cascadia Code NF installed ($($ttfs.Count) fonts)" -ForegroundColor Green
} finally {
    Remove-Item -Recurse -Force $TmpDir -ErrorAction SilentlyContinue
}
{{- end -}}
