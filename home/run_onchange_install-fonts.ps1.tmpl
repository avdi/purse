{{- if eq .chezmoi.os "windows" -}}
# chezmoi run_onchange: install Cascadia Code NF — Windows
#
# Downloads directly from microsoft/cascadia-code GitHub releases, which
# ships NF variants officially (no third-party repackaging).
# Per-user install into %LOCALAPPDATA%\Microsoft\Windows\Fonts — no admin required.
# Registers each font in HKCU so Windows recognises it immediately.
#
# Re-runs whenever this script changes (e.g. to bump the font version).
# Font version: 2407.24
$ErrorActionPreference = 'Stop'

$FontVersion = '2407.24'
$ArchiveName = "CascadiaCode-$FontVersion.zip"
$DownloadUrl = "https://github.com/microsoft/cascadia-code/releases/download/v$FontVersion/$ArchiveName"
$FontDir     = "$env:LOCALAPPDATA\Microsoft\Windows\Fonts"
$RegPath     = 'HKCU:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts'

if (Test-Path "$FontDir\CascadiaCodeNF-Regular.ttf") {
    Write-Host "→ Cascadia Code NF already installed in $FontDir"
    exit 0
}

Write-Host "→ Installing Cascadia Code NF v$FontVersion from microsoft/cascadia-code..." -ForegroundColor Cyan

if (-not (Test-Path $FontDir)) {
    New-Item -ItemType Directory -Path $FontDir -Force | Out-Null
}

$TmpDir = Join-Path $env:TEMP "cascadia-code-$FontVersion"
New-Item -ItemType Directory -Path $TmpDir -Force | Out-Null

try {
    $ArchivePath = Join-Path $TmpDir $ArchiveName
    Write-Host "  Downloading $DownloadUrl..."
    Invoke-WebRequest -Uri $DownloadUrl -OutFile $ArchivePath -UseBasicParsing

    Write-Host "  Extracting NF TTF files..."
    Expand-Archive -Path $ArchivePath -DestinationPath $TmpDir -Force

    # Install only the NF variants (ttf/static/CascadiaCodeNF-*.ttf)
    $ttfs = Get-ChildItem -Path (Join-Path $TmpDir 'ttf\static') -Filter 'CascadiaCodeNF-*.ttf'
    foreach ($ttf in $ttfs) {
        $dest = Join-Path $FontDir $ttf.Name
        Copy-Item -Path $ttf.FullName -Destination $dest -Force
        $regName = $ttf.BaseName + ' (TrueType)'
        Set-ItemProperty -Path $RegPath -Name $regName -Value $ttf.Name -Force
    }

    Write-Host "✓ Cascadia Code NF installed ($($ttfs.Count) fonts)" -ForegroundColor Green
} finally {
    Remove-Item -Recurse -Force $TmpDir -ErrorAction SilentlyContinue
}
{{- end -}}
