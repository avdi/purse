#!/bin/bash
# chezmoi run_once: bootstrap lenticel (frp tunnel client)
# Delegates to lenticel-bootstrap.sh in the repo root, which handles
# Codespace detection and Zoho Vault token resolution internally.
#
# With .chezmoiroot = home, .chezmoi.sourceDir is the home/ subdirectory.
# The repo root is one level up via | dir.

bash "{{ .chezmoi.sourceDir | dir }}/lenticel-bootstrap.sh"
